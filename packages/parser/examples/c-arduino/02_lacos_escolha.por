programa
{
  funcao inicio()
  {
    inteiro soma = 0
    inteiro i = 0

    para (i = 0; i < 5; i++)
    {
      soma += i
    }

    enquanto (soma < 20)
    {
      soma += 2
    }

    faca
    {
      soma--
    }
    enquanto (soma > 10)

    escolha (soma)
    {
      caso 10:
        escreva("dez")
        pare

      caso contrario:
        escreva("outro")
    }
  }
}
